# =============================================================================
# Continue.dev Secrets — Vorlage
# =============================================================================
# Diese Datei so speichern:
#   - global:   ~/.continue/.env
#   - projekt:  <workspace-root>/.continue/.env
#
# Danach umbenennen zu ".env" (ohne ".example") und die echten Keys eintragen.
# Continue löst ${{ secrets.NAME }} aus der config.yaml automatisch gegen
# diese Datei auf.
# =============================================================================

ZAI_API_KEY=dein-echter-z-ai-key
TAVILY_API_KEY=dein-echter-tavily-key
CLOUDFLARE_ACCOUNT_ID=deine_cloudflare_account_id
CLOUDFLARE_API_TOKEN=dein_cloudflare_api_token

# GitHub MCP: Personal Access Token mit "repo"-Scope erstellen unter
# https://github.com/settings/tokens (classic) oder als Fine-grained Token
GITHUB_PERSONAL_ACCESS_TOKEN=dein-echter-github-token

# Context7 MCP: optional! Server funktioniert auch leer/fehlend (Basis-Limit).
# Kostenlosen Key holen unter https://context7.com/dashboard fuer hoehere Limits.
CONTEXT7_API_KEY=

