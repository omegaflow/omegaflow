# Fire (NASA FIRMS - separate from NASA_KEY)
FIRMS_MAP_KEY=

# Biology
EBIRD_KEY=

# Energy & Markets
EIA_KEY=
AV_KEY=
ELECTRICITYMAPS_TOKEN=

# Geophysics
SUPERMAG_USER=

# Internet
CLOUDFLARE_TOKEN=

# Conflict
ACLED_KEY=
ACLED_EMAIL=
