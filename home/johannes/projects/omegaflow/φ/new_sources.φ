source irish_rail_realtime
ttl 60
format xml
url https://api.irishrail.ie/realtime/realtime.asmx/getStationDataByCodeXML?StationCode=BROC
count ArrayOfObjStationData.ObjStationData technosphere_train_departures_dublin

source ripe_bgp_default_route
ttl 300
url https://stat.ripe.net/data/bgp-state/data.json?resource=0.0.0.0/0
count data.bgp_state technosphere_internet_bgp_routes_default

source celestrak_earth_orientation
ttl 86400
url https://celestrak.org/SpaceData/EOP-All.csv
format csv
last_row UT1-UTC geosphere_ut1_utc_offset
last_row LOD geosphere_length_of_day_ms
last_row X geosphere_pole_x_arcsec
last_row Y geosphere_pole_y_arcsec

source icgem_geoid_height
ttl 2592000
url https://icgem.gfz-potsdam.de/calcgrid?model=EGM2008&functype=geoid_undulation&lat={lat}&lon={lon}&format=gdf
format csv
last_row undulate geosphere_geoid_height_m

source nasa_dsn_status
ttl 60
url https://eyes.nasa.gov/dsn-now/dsn.json
count dsn technosphere_nasa_deep_space_network_signals

source who_cholera
ttl 2592000
