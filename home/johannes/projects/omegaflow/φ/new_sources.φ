source ndbc_buoy_41001
ttl 300
url https://www.ndbc.noaa.gov/data/realtime2/41001.txt
format csv
last_row WDIR hydrosphere_buoy_41001_wind_dir
last_row WSPD hydrosphere_buoy_41001_wind_speed
last_row WVHT hydrosphere_buoy_41001_wave_height
last_row DPD hydrosphere_buoy_41001_dominant_period
last_row PRES hydrosphere_buoy_41001_pressure
last_row WTMP hydrosphere_buoy_41001_water_temp

source noaa_tides_salinity_8771450
ttl 300
url https://api.tidesandcurrents.noaa.gov/api/prod/datagetter?begin_date={today}&end_date={tomorrow}&station=8771450&product=salinity&time_zone=utc&units=metric&format=json
last data.0.v hydrosphere_salinity_galveston

source openmeteo_thunderstorm
ttl 600
url https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&daily=thunderstorm_max_intensity
field daily.thunderstorm_max_intensity.0 atmosphere_thunderstorm_max_intensity

source cdc_covid_global
ttl 3600
url https://disease.sh/v3/covid-19/all
field cases anthroposphere_covid_cases_global
field deaths anthroposphere_covid_deaths_global
field active anthroposphere_covid_active_global
field critical anthroposphere_covid_critical_global

source ecdc_monkeypox
ttl 86400
url https://opendata.ecdc.europa.eu/monkeypox/casedistribution/csv/data.csv
format csv
