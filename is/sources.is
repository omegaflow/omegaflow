source openmeteo_weather on_earth
ttl 600
url https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current=temperature_2m,relative_humidity_2m,apparent_temperature,is_day,precipitation,rain,showers,snowfall,weather_code,cloud_cover,pressure_msl,surface_pressure,wind_speed_10m,wind_direction_10m,wind_gusts_10m&timezone=auto
field current.temperature_2m weather_temp_c
field current.relative_humidity_2m weather_humidity_pct
field current.pressure_msl weather_pressure_hpa
field current.wind_speed_10m weather_wind_speed_ms
field current.wind_direction_10m weather_wind_direction_deg
field current.cloud_cover weather_cloud_cover_pct
field current.precipitation weather_precipitation_mm

source openmeteo_air_quality_full on_earth
ttl 600
