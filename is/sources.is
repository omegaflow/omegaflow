url https://ssd.jpl.nasa.gov/api/horizons.api?format=json&COMMAND=%27Vesta%3B%27&OBJ_DATA=%27NO%27&MAKE_EPHEM=%27YES%27&EPHEM_TYPE=%27VECTORS%27&CENTER=%27500%400%27&START_TIME=%27{today}%27&STOP_TIME=%27{tomorrow}%27&STEP_SIZE=%271%20d%27
vector vesta_x vesta_y vesta_z

source voyager1_vectors
ttl 86400
url https://ssd.jpl.nasa.gov/api/horizons.api?format=json&COMMAND=%27-31%27&OBJ_DATA=%27NO%27&MAKE_EPHEM=%27YES%27&EPHEM_TYPE=%27VECTORS%27&CENTER=%27500%400%27&START_TIME=%27{today}%27&STOP_TIME=%27{tomorrow}%27&STEP_SIZE=%271%20d%27
vector voyager1_x voyager1_y voyager1_z

source voyager2_vectors
ttl 86400
url https://ssd.jpl.nasa.gov/api/horizons.api?format=json&COMMAND=%27-32%27&OBJ_DATA=%27NO%27&MAKE_EPHEM=%27YES%27&EPHEM_TYPE=%27VECTORS%27&CENTER=%27500%400%27&START_TIME=%27{today}%27&STOP_TIME=%27{tomorrow}%27&STEP_SIZE=%271%20d%27
vector voyager2_x voyager2_y voyager2_z

source who_influenza
ttl 86400
url https://xmart-api-public.who.int/FLUMART/V_FLUNET?$format=json&$top=5&$orderby=ISO_YEAR%20desc,ISO_WEEK%20desc
field value.0.ALL_INF biosphere_influenza_positive_global
field value.0.SPEC_PROCESSED_NB biosphere_influenza_specimens_global

source xenocanto_birds
ttl 86400
url https://xeno-canto.org/api/2/recordings?query=box:{lat_min},{lon_min},{lat_max},{lon_max}
field numRecordings biosphere_bird_sound_recordings
field numSpecies biosphere_bird_species_recorded

source elevation
ttl 604800
url https://api.open-meteo.com/v1/elevation?latitude={lat}&longitude={lon}
first elevation topography_elevation

source geopages
ttl 604800
url https://en.wikipedia.org/w/api.php?action=query&list=geosearch&gscoord={lat}|{lon}&gsradius=10000&gslimit=500&format=json
count query.geosearch geopages_nearby

source crdb_cosmic_rays
ttl 2592000
url https://lpsc.in2p3.fr/crdb/rest/?request=GET&num=208&energy_convert_level=rigidity&combo_level=0&output=json
count data cosmic_ray_measurements_crdb

source noaa_enso_oni
ttl 2592000
url https://www.cpc.ncep.noaa.gov/data/indices/oni.ascii.txt
last_row ANOM climate_enso_oni_index_celsius

source crystallography_xrd
ttl 2592000
url https://www.crystallography.net/cod/result.php?format=json&el=Si&limit=1
field a lattice_constant_angstrom

source dome_fuji_co2
ttl 2592000
url https://www.ncei.noaa.gov/pub/data/paleo/icecore/antarctica/domefuji/domefuji2017co2.txt
format csv
last_row age_bp paleoclimate_domefuji_age_bp
last_row co2 paleoclimate_domefuji_co2_ppm

source erddap_socat_gridded
ttl 2592000
url https://coastwatch.pfeg.noaa.gov/erddap/griddap/socat_v2022_clim.json?fco2_ave_unwtd[(last)][(last)][({lat})][({lon})]
field fco2_ave_unwtd ocean_co2_climatology_uatm

source ice_core_lead_pollution
ttl 2592000
url https://www.ncei.noaa.gov/pub/data/paleo/icecore/greenland/summit/gisp2/chem/pb.txt
format csv
last_row age_yb1950 paleoclimate_lead_pollution_age_yr
last_row pb_ng_g paleoclimate_lead_concentration_ppb

source macrostrat_ages
ttl 2592000
url https://macrostrat.org/api/v2/units?age_top=0&age_bottom=4600&format=json&response=long
field total geology_macrostrat_unit_count

source macrostrat_timescale
ttl 2592000
url https://macrostrat.org/api/v2/timescales?timescale_id=11
field intervals geology_ics_timescale_units

source noaa_paleoclimate_co2
ttl 2592000
url https://www.ncei.noaa.gov/pub/data/paleo/icecore/antarctica/epica_domec/edc3deuttemp2007.txt
format csv
field age_bp paleoclimate_age_bp
field temperature paleoclimate_temp_anomaly_c

source viirs_nighttime_lights
ttl 2592000
url https://coastwatch.pfeg.noaa.gov/erddap/griddap/erdVH2018nldmday.json?nLD_filled[(last)][(last)][({lat})][({lon})]
field nLD_filled technosphere_nighttime_light_radiance

source vostok_icecore
ttl 2592000
url https://www.ncei.noaa.gov/pub/data/paleo/icecore/antarctica/vostok/deutnat.txt
format csv
last_row age_bp paleoclimate_vostok_age_bp
last_row CO2 paleoclimate_vostok_co2_ppm

source wais_divide_co2
ttl 2592000
url https://www.ncei.noaa.gov/pub/data/paleo/icecore/antarctica/wais-divide/WDC_CO2_68ka_2015.txt
format csv
last_row age_bp paleoclimate_wais_age_bp
last_row co2 paleoclimate_wais_co2_ppm

source who_gho_tuberculosis
ttl 2592000
url https://ghoapi.azureedge.net/api/MDG_0000000020
field value.0.NumericValue biosphere_tuberculosis_incidence_rate

source worldbank_co2_emissions
ttl 2592000
url https://api.worldbank.org/v2/country/WLD/indicator/EN.ATM.CO2E.KT?format=json&per_page=1&date=2023
field 1.0.value climate_global_co2_emissions_kt

source worldbank_population
ttl 2592000
url https://api.worldbank.org/v2/country/WLD/indicator/SP.POP.TOTL?format=json&per_page=1&date=2023
field 1.0.value technosphere_global_population

source cern_cms_data
ttl 31536000
url http://opendata.cern.ch/api/records/?type=dataset&experiment=CMS&size=1
field hits.total cern_cms_datasets

source cern_open_data
ttl 31536000
url http://opendata.cern.ch/api/records/?type=dataset&size=0
field hits.total cosmic_cern_datasets

source esa_gaia_stars
ttl 31536000
url https://gea.esac.esa.int/tap-server/tap/sync?REQUEST=doQuery&LANG=ADQL&FORMAT=json&QUERY=SELECT+TOP+50+source_id,ra,dec,phot_g_mean_mag,parallax+FROM+gaiadr3.gaia_source+WHERE+phot_g_mean_mag+<+3.0+ORDER+BY+phot_g_mean_mag
count data cosmic_bright_stars_count
path data.0.ra cosmic_star_ra
path data.0.dec cosmic_star_dec
path data.0.phot_g_mean_mag cosmic_star_magnitude
path data.0.parallax cosmic_star_parallax_mas

source gaia_nearby_stars
ttl 31536000
url https://gea.esac.esa.int/tap-server/tap/sync?REQUEST=doQuery&LANG=ADQL&FORMAT=json&QUERY=SELECT+COUNT(*)+as+n+FROM+gaiadr3.gaia_source+WHERE+parallax+>+100
path data.0.0 cosmic_nearby_stars_10pc

source gaia_stellar_ages
ttl 31536000
url https://gea.esac.esa.int/tap-server/tap/sync?REQUEST=doQuery&LANG=ADQL&FORMAT=json&QUERY=SELECT+TOP+5+source_id,age_flame,mass_flame,teff_gspphot+FROM+gaiadr3.astrophysical_parameters+WHERE+age_flame+IS+NOT+NULL+ORDER+BY+age_flame+DESC
field age_flame cosmology_oldest_star_age_gyr
field teff_gspphot cosmology_oldest_star_temp_k

source gaia_total_measured_stars
ttl 31536000
url https://gea.esac.esa.int/tap-server/tap/sync?REQUEST=doQuery&LANG=ADQL&FORMAT=json&QUERY=SELECT+COUNT(*)+as+n+FROM+gaiadr3.gaia_source+WHERE+parallax>0
path data.0.0 cosmic_total_measured_stars

source gaia_variable_stars
ttl 31536000
url https://gea.esac.esa.int/tap-server/tap/sync?REQUEST=doQuery&LANG=ADQL&FORMAT=json&QUERY=SELECT+COUNT(*)+as+n+FROM+gaiadr3.vari_classifier_result
path data.0.0 cosmic_variable_stars_count

source gaia_white_dwarfs
ttl 31536000
url https://gea.esac.esa.int/tap-server/tap/sync?REQUEST=doQuery&LANG=ADQL&FORMAT=json&QUERY=SELECT+COUNT(*)+as+n+FROM+gaiadr3.astrophysical_parameters+WHERE+classprob_dsc_combmod_wd+%3E+0.8
path data.0.0 cosmology_white_dwarf_count_gaia

source nasa_exoplanet_total
ttl 31536000
url https://exoplanetarchive.ipac.caltech.edu/TAP/sync?query=SELECT+COUNT(*)+as+n+FROM+ps+WHERE+pl_rade+IS+NOT+NULL&format=json
path 0.n cosmic_exoplanet_total_confirmed

source nasa_exoplanets
ttl 31536000
url https://exoplanetarchive.ipac.caltech.edu/TAP/sync?query=SELECT+TOP+20+pl_name,pl_orbper,pl_rade,pl_eqt+FROM+pscomppars+WHERE+pl_eqt+IS+NOT+NULL+ORDER+BY+pl_eqt+ASC&format=json
count data cosmic_exoplanet_count
field pl_eqt cosmic_exoplanet_temp_k
field pl_orbper cosmic_exoplanet_period_days
field pl_rade cosmic_exoplanet_radius_earth

source nasa_hot_jupiters
ttl 31536000
url https://exoplanetarchive.ipac.caltech.edu/TAP/sync?query=SELECT+COUNT(*)+as+n+FROM+ps+WHERE+pl_orbper<1&format=json
path 0.n cosmic_hot_jupiters

