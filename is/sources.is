source atmosphere on_earth
    url https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&current=temperature_2m,wind_speed_10m,surface_pressure,relative_humidity_2m,precipitation&hourly=cloud_cover
    field temperature_2m atmosphere_temp
    field wind_speed_10m atmosphere_wind
    field surface_pressure atmosphere_pressure
    field relative_humidity_2m atmosphere_humidity
    field precipitation atmosphere_precipitation
    first cloud_cover atmosphere_cloud_cover

source elevation on_earth
    url https://api.open-meteo.com/v1/elevation?latitude={lat}&longitude={lon}
    first elevation topography_elevation

source biosphere on_earth
    url https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}&hourly=soil_temperature_0cm,soil_moisture_0_to_1cm,et0_fao_evapotranspiration,vapor_pressure_deficit
    first soil_temperature_0cm biosphere_soil_temp
    first soil_moisture_0_to_1cm biosphere_soil_moisture
    first et0_fao_evapotranspiration biosphere_evapotranspiration
    first vapor_pressure_deficit biosphere_vpd

source airquality on_earth
    url https://air-quality-api.open-meteo.com/v1/air-quality?latitude={lat}&longitude={lon}&current=pm10,pm2_5,european_aqi,carbon_monoxide,nitrogen_dioxide,sulphur_dioxide,ozone
    field pm10 atmosphere_pm10
    field pm2_5 atmosphere_pm25
    field european_aqi atmosphere_aqi
    field carbon_monoxide atmosphere_co
    field nitrogen_dioxide atmosphere_no2
    field sulphur_dioxide atmosphere_so2
    field ozone atmosphere_ozone

source marine on_earth
    url https://marine-api.open-meteo.com/v1/marine?latitude={lat}&longitude={lon}&current=wave_height,wave_direction,wave_period
    field wave_height ocean_wave_height
    field wave_direction ocean_wave_direction
    field wave_period ocean_wave_period

source seismic on_earth
    url https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
    geojson nearby 500000 mag 2.0 seismic_magnitude seismic_depth seismic_distance

source magnetism
    url https://services.swpc.noaa.gov/products/solar-wind/mag-7-day.json
    last_row bz_gsm magnetism_bz
    last_row bt magnetism_bt

source plasma
    url https://services.swpc.noaa.gov/products/solar-wind/plasma-7-day.json
    last_row speed solar_wind_speed
    last_row density solar_wind_density
    last_row temperature solar_wind_temp

source kp_index
    url https://services.swpc.noaa.gov/json/planetary_k_index_1m.json
    last kp_index kp_index

source xray
    url https://services.swpc.noaa.gov/json/goes/primary/xrays-1-day.json
    last flux xray_flux

source radio_flux
    url https://services.swpc.noaa.gov/json/solar-radio-flux.json
    last flux solar_radio_flux

source protons
    url https://services.swpc.noaa.gov/json/goes/primary/integral-protons-1-day.json
    last_obj energy ">=100 MeV" flux cosmic_protons_100mev

source sun_vectors
    url https://ssd.jpl.nasa.gov/api/horizons.api?format=json&COMMAND=%2710%27&OBJ_DATA=%27NO%27&MAKE_EPHEM=%27YES%27&EPHEM_TYPE=%27VECTORS%27&CENTER=%27500%400%27&START_TIME=%272026-06-22%27&STOP_TIME=%272026-06-23%27&STEP_SIZE=%271%20d%27
    vector sun_x sun_y sun_z

source mars_vectors
    url https://ssd.jpl.nasa.gov/api/horizons.api?format=json&COMMAND=%27499%27&OBJ_DATA=%27NO%27&MAKE_EPHEM=%27YES%27&EPHEM_TYPE=%27VECTORS%27&CENTER=%27500%400%27&START_TIME=%272026-06-22%27&STOP_TIME=%272026-06-23%27&STEP_SIZE=%271%20d%27
    vector mars_x mars_y mars_z

source iss_tle
    url https://celestrak.org/NORAD/elements/gp.php?GROUP=stations&FORMAT=json
    first MEAN_MOTION iss_mean_motion
    first INCLINATION iss_inclination
    first ECCENTRICITY iss_eccentricity

source inaturalist on_earth
    url https://api.inaturalist.org/v1/observations?lat={lat}&lng={lon}&radius=1&per_page=0
    field total_results biosphere_observations

source gbif on_earth
    url https://api.gbif.org/v1/occurrence/search?decimalLatitude={lat}&decimalLongitude={lon}&radius=1&limit=0
    field count biosphere_species_count

source geopages on_earth
    url https://en.wikipedia.org/w/api.php?action=query&list=geosearch&gscoord={lat}|{lon}&gsradius=10000&format=json
    count geosearch geopages_nearby

source aviation on_earth
    url https://opensky-network.org/api/states/all?lamin={lat_min}&lomin={lon_min}&lamax={lat_max}&lomax={lon_max}
    count states aviation_aircraft

source mercury_vectors
    url https://ssd.jpl.nasa.gov/api/horizons.api?format=json&COMMAND=%27199%27&OBJ_DATA=%27NO%27&MAKE_EPHEM=%27YES%27&EPHEM_TYPE=%27VECTORS%27&CENTER=%27500%400%27&START_TIME=%272026-06-22%27&STOP_TIME=%272026-06-23%27&STEP_SIZE=%271%20d%27
    vector mercury_x mercury_y mercury_z

