field current.pm2_5 atmosphere_pm25_station
field current.pm10 atmosphere_pm10_station
field current.nitrogen_dioxide atmosphere_no2_station
field current.carbon_monoxide atmosphere_co_station
field current.sulphur_dioxide atmosphere_so2_station
field current.ozone atmosphere_o3_station

