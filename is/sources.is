source sdss_cosmic_web_galaxies
ttl 31536000
url https://skyserver.sdss.org/dr18/SkyServerWS/SearchTools/SqlSearch?cmd=SELECT+TOP+1+COUNT(*)+as+n+FROM+SpecObj+WHERE+class='GALAXY'+AND+z+BETWEEN+0.1+AND+0.2
path 0.Rows.0.n cosmic_galaxies_mid_redshift_count

